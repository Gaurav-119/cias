# ---- Core ----
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-jwt-secret
JWT_ACCESS_HOURS=12
AUTO_CREATE_TABLES=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_UPLOAD_MB=50

# ---- Database ----
# Local PostgreSQL (no Docker)
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/cias
#
# Docker Compose PostgreSQL
# DATABASE_URL=postgresql+psycopg2://cias:cias@db:5432/cias
#
# SQLite (zero-setup fallback)
# DATABASE_URL=sqlite:///cias.db

# ---- Storage abstraction: local | minio | s3 ----
STORAGE_PROVIDER=local
STORAGE_BUCKET=cias-media
LOCAL_STORAGE_DIR=./storage

# MinIO (only when STORAGE_PROVIDER=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# AWS S3 (only when STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=

# ---- AI service ----
# Local (no Docker)
AI_SERVICE_URL=http://localhost:8000
# Docker Compose
# AI_SERVICE_URL=http://ai:8000

# ---- Payments: record | stripe ----
PAYMENT_MODE=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
